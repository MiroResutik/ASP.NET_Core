@page "/weather"
@inject HttpClient Http

<PageTitle>Weather</PageTitle>

<h1>Weather</h1>

<p>This component demonstrates fetching data from the server.</p>

<h4>Enter city</h4>
<input type="text" @bind="@City"/>

@if (forecasts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    var today = DateTime.Today;
    <h4>Today: @today.ToShortDateString()</h4>
    <p>Temp. (C):  @forecasts.timezone</p>
    <p>Humidity @forecasts.elevation</p>
    <p>Wind Speed @forecasts.timezone_abbreviation</p>

    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Temp. (C)</th>
                <th>Humidity</th>
                <th>Wind Speed</th>
                
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in forecasts.Forecast)
            {
                <tr>
                    <td>@today.ToShortDateString()</td>
                    <td>@forecast.timezone</td>
                    <td>@forecast.elevation</td>
                    <td>@forecast.timezone_abbreviation</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {


    private WeatherForecast? forecasts;

    private string City = ""; // Bristol 
    public partial class WeatherForecast : Forecast
    {
        public string? Description { get; set; }
        public Forecast[]? Forecast { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        forecasts = await Http.GetFromJsonAsync<WeatherForecast>("forecast?latitude=52.52&longitude=13.41&hourly=temperature_2m");
    }

    //Reading from API json

    public class Forecast
    {
        public string? timezone { get; set; } //Temperature

        public string? elevation { get; set; }

        public string? timezone_abbreviation { get; set; }

        
    }

